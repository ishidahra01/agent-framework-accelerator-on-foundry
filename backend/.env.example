# Foundry project endpoint the agent connects to.
# Either name works; FOUNDRY_PROJECT_ENDPOINT takes precedence over AZURE_AI_PROJECT_ENDPOINT.
FOUNDRY_PROJECT_ENDPOINT=
AZURE_AI_PROJECT_ENDPOINT=

# Model deployment name used by FoundryChatClient (e.g. gpt-4o, gpt-4.1).
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Authentication uses DefaultAzureCredential: run `az login` locally, or rely on
# managed identity when deployed. No API keys are required.

# Agent identity and runtime behaviour.
FOUNDRY_AGENT_NAME=azure-resource-analyzer
FOUNDRY_AGENT_VERSION=
# workflow = explore -> security/cost/architecture -> synthesize (default).
# single = one coordinator agent with all tools and skills.
AGENT_RUNTIME_MODE=workflow

# Filesystem workspace root for exported Azure configuration and generated reports.
AGENT_WORKSPACE_ROOT=work

# Shell tool is disabled by default. Set to true to allow guarded shell execution.
AGENT_ENABLE_SHELL_TOOL=false

# Optional local telemetry configuration. Hosted Agent deployments normally inject this value.
APPLICATIONINSIGHTS_CONNECTION_STRING=
ENABLE_INSTRUMENTATION=true
ENABLE_SENSITIVE_DATA=true
ENABLE_CONSOLE_EXPORTERS=false
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
